package.xml
# LWC configuration files
**/jsconfig.json
**/.eslintrc.json
# LWC Jest
**/__tests__/**
**/appMenu/**
**/appSwitcher/**
**/appMenus/AppSwitcher.appMenu-meta.xml
**/connectedApps/**
**/certs/**
**/profilePasswordPolicies/**
**SfdxHardisDeferSharingRecalc
# Salesforce DevOps Center internal objects (not deployable)
**/objects/DevopsEnvironment*
**/objects/DevopsRequestInfo*
**/objects/UserDevopsPreference*
# Layouts with managed package dependencies
**/layouts/Event-Event Layout*
**/layouts/Task-Task Layout*
# QuickActions with invalid label values
**/quickActions/GuestCommunityCase*
**/quickActions/NewCommunityCase***
# Standard namespace CustomApplications (cannot be deployed via API)
**/applications/standard__DigitalWallet*
**/applications/standard__Integration*
**/applications/standard__LightningInstrumentation*
**/applications/**
**/profiles/**
**/emailservices/**
# PermissionSets with cadmus_contract managed package dependency (not installed in UAT)
**/permissionsets/CONTRACT_Butler_Admin_Local*
**/permissionsets/CONTRACT_Butler_User_Local*
# SharingRules with missing sharingCriteriaRules
**/sharingRules/DialerCallUsage*
**/sharingRules/SiqOrgMigrationStatus*
**/sharingRules/UnstructuredStorageSpace*
# FlowDefinition is a deprecated metadata type — active version is managed directly in each org
**/flowDefinitions/**
# Standard org settings - don't retrieve
settings/
standardValueSets/
globalValueSetTranslations/
objectTranslations/
moderation/
topicsForObjects/
profilePasswordPolicies/
profileSessionSettings/
installedPackages/
