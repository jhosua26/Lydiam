<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Role_Summary__c</fullName>
    <description>Formula field that displays the concatenated roles (Shareholder, Director, or both).</description>
    <externalId>false</externalId>
    <formula>IF(Is_Shareholder__c &amp;&amp; Is_Director__c, 
    &quot;Shareholder; Director&quot;,
IF(Is_Shareholder__c, 
    &quot;Shareholder&quot;,
IF(Is_Director__c, 
    &quot;Director&quot;, 
    &quot;&quot;)))</formula>
    <label>Role Summary</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
