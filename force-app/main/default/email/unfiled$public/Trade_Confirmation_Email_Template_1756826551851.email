															<div style="font-family: Arial, sans-serif; color: #333; font-size: 14px; line-height: 1.6; max-width: 600px; margin: 0 auto; border: 1px solid #ddd; padding: 20px;">
															<h2 style="color:#006400; margin-bottom:10px;">Details of your transaction</h2>

															<p style="margin:0 0 15px 0;">Here's a summary of your transaction. If you need further details you can view and download them from your account.</p>

															<table style="width:100%; border-collapse: collapse; margin-bottom: 20px;">
																
																	<tr>
																		<td style="padding: 8px 0; font-weight:bold;">Account name</td>
																		<td style="padding: 8px 0;">{{ClientName}}</td>
																	</tr>
																	<tr>
																		<td style="padding: 8px 0; font-weight:bold;">Account reference</td>
																		<td style="padding: 8px 0;">{{ClientRefNumber}}</td>
																	</tr>
																
															</table>

															<h3 style="color:#006400; margin:20px 0 10px 0;">Currency conversion details</h3>

															<table style="width:100%; border-collapse: collapse; margin-bottom: 20px;">
																
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Sell currency</td>
																		<td style="padding: 6px 0;">{{Amount}} {{TickerSell}}</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Exchange rate</td>
																		<td style="padding: 6px 0;">{{ExchangeRate}}</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Transaction fee</td>
																		<td style="padding: 6px 0;">{{TransactionFee}} {{Ticker}}</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Settlement date</td>
																		<td style="padding: 6px 0;">{{SettlementDate}}</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Buy currency</td>
																		<td style="padding: 6px 0;">{{Amount}} {{TickerBuy}}</td>
																	</tr>
																
															</table>

															<hr style="border: none; border-top: 1px solid #ddd; margin: 20px 0;" />
															<div style="margin: 20px 0;"><span style="display:inline-block; background:#e74c3c; color:#fff; padding:6px 12px; border-radius:4px; font-size:13px; font-weight:bold;">⚠ Action Required </span></div>

															<p style="margin:0 0 15px 0;">Use your bank's online banking platform or mobile app to pay for your transaction. Remember to include the below reference.</p>

															<hr style="border: none; border-top: 1px solid #ddd; margin: 20px 0;" />
															<table style="width:100%; border-collapse: collapse; margin-bottom: 20px;">
																
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Amount to send us</td>
																		<td style="padding: 6px 0;">{{BuyAmount}} {{BuyTicker}}</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Add payment reference</td>
																		<td style="padding: 6px 0;">{{ClientDealNumber}}</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Payee name</td>
																		<td style="padding: 6px 0;">Lydiam Group</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Sort Code</td>
																		<td style="padding: 6px 0;">20-00-00</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">IBAN</td>
																		<td style="padding: 6px 0;">GB85BARC2000066235188</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Bank code (SWIFT/BIC)</td>
																		<td style="padding: 6px 0;">BARCGB22</td>
																	</tr>
																	<tr>
																		<td style="padding: 6px 0; font-weight:bold;">Our bank address</td>
																		<td style="padding: 6px 0;">1 Churchill Place London E14 5HP United Kingdom</td>
																	</tr>
																
															</table>
