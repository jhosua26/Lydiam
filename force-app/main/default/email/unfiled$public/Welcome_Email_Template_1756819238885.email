												<td background="https://raw.githubusercontent.com/georgepanayides/lydiamemails/main/Gradient.jpg" bgcolor="transparent" class="pc-w520-padding-27-30-27-30 pc-w620-padding-32-35-32-35" style="background-image: url('https://raw.githubusercontent.com/georgepanayides/lydiamemails/main/Gradient.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat; padding: 15px 15px 15px 15px; height: unset; border-radius: 10px 10px 10px 10px; background-color: transparent; box-shadow: 0px 0px 10px 0px rgba(0,0,0,0.16);" valign="top">
												<table border="0" cellpadding="0" cellspacing="0" width="100%">
